{
  "name": "signalk-gpio-beeper-plugin",
  "version": "1.1.4",
  "description": "A Signal K plugin that activates a Raspberry Pi GPIO beeper when a Signal K alarm condition exists",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-utility",
    "signalk",
    "alarm",
    "beeper"
  ],
  "signalk-plugin-enabled-by-default": true,
  "signalk": {
    "displayName": "GPIO Beeper Alarm"
  },
  "license": "MIT",
  "author": "Jeremy Waters <jaffadog@gmail.com>",
  "main": "plugin/index.js",
  "type": "commonjs",
  "scripts": {
    "format": "npx prettier . --write",
    "format:check": "npx prettier . --check",
    "lint": "eslint .",
    "test": "node --test",
    "checks": "npm run format:check && npm run lint && npm run test",
    "preversion": "npm run checks",
    "changelog": "node scripts/generate-changelog.mjs",
    "version": "npm run changelog"
  },
  "dependencies": {},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaffadog/signalk-gpio-beeper-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/jaffadog/signalk-gpio-beeper-plugin/issues"
  },
  "homepage": "https://github.com/jaffadog/signalk-gpio-beeper-plugin",
  "devDependencies": {
    "@eslint/css": "^1.4.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@eslint/markdown": "^8.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5"
  }
}
